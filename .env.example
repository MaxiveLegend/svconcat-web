# Copy to ".env" (same folder as docker-compose.yml) and fill in real values.
# docker compose auto-loads this file and interpolates ${VAR} in the compose file.
# The real .env is gitignored; CI writes it from GitHub Actions secrets at deploy.

# Initial Umbraco backoffice admin (used ONLY on first boot to seed the DB;
# ignored once umbraco-data already contains a database).
UMBRACO_ADMIN_NAME=Administrator
UMBRACO_ADMIN_EMAIL=admin@example.com
UMBRACO_ADMIN_PASSWORD=change-me-to-a-strong-password
