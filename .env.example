# Copy to ".env" (same folder as docker-compose.yml) for LOCAL development.
#
# In CI these values come from GitHub Actions secrets injected as environment
# variables (see .github/workflows/deploy.yml) — no .env is written there.
#
# IMPORTANT: a literal "$" in any value MUST be escaped as "$$", otherwise
# docker compose interprets it as a variable reference and mangles the value.
# e.g. a password of  ab$Yz  must be written here as  ab$$Yz

# HTTPS handling. Leave true (or unset) for production, but set to false for local dev
UMBRACO_USE_HTTPS=false

# Initial Umbraco backoffice admin — used ONLY on first boot to seed the DB;
# ignored once the umbraco-data volume already contains a database.
Umbraco__CMS__Unattended__UnattendedUserName=Administrator
Umbraco__CMS__Unattended__UnattendedUserEmail=admin@example.com
Umbraco__CMS__Unattended__UnattendedUserPassword=change-me-to-a-strong-password
