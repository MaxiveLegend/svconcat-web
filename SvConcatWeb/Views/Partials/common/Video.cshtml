@using SvConcatWeb.Extensions.ViewModels.Blocks
@model VideoBlockViewModel

<div class="c-video" data-component="video">
    <div class="c-video__thumbnail-container">
                
        @if (Model.HasThumbnail)
        {
            <picture class="c-video__thumbnail">

                @foreach (var source in Model.Thumbnail.Sources)
                {
                    <source srcset="@source.Src" media="@source.MediaQuery">
                }

                <img src="@Model.Thumbnail.Url" alt="@Model.Thumbnail.Alt">
            </picture>
        }

        <button class="c-video__play-button" aria-label="Video afspelen">
            <svg class="c-icon c-video__play-icon" aria-hidden="true"><use href="/dist/images/icons/sprite.svg#play"></use></svg>
        </button>
    </div>

    <video>
        <source src="@Model.GetFullUrl" type="video/mp4">
    </video>
</div>