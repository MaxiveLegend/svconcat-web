@inherits UmbracoViewPage<SvConcatWeb.Extensions.Models.IMasterModel>

@{
    Layout = null;
}

<!DOCTYPE html>

<html lang="nl">
<head>
    <title>@Model.SeoTitle | @Model.SeoSiteName</title>

    <link rel="stylesheet" href="/dist/styles.css">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Quicksand">
</head>
<body>

@await Component.InvokeAsync("Header", new { model = Model })

<main>
    @RenderBody()
</main>

@await Component.InvokeAsync("Footer", new { model = Model })

</body>
</html>