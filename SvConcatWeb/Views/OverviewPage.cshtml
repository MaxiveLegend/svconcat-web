@inherits UmbracoViewPage<SvConcatWeb.Extensions.Models.MasterModel<OverviewPage>>
@using Umbraco.Cms.Web.Common.PublishedModels

@{
    Layout = "Master.cshtml";

    const int pageSize = 12;
    const string overviewEndpoint = "/umbraco/api/overview/items";

    // Read child event years straight from the published cache so the year stepper
    // can be clamped to years that actually contain content.
    var fallbackYear = DateTime.UtcNow.Year;
    var availableYears = Model.Content
        .Children<OverviewDetailPage>()
        .Where(child => child.IsVisible())
        .Select(child => child.Value<DateTime>("eventDate").Year)
        .Where(year => year > 1) // ignore items missing an eventDate (DateTime.MinValue)
        .Distinct()
        .OrderBy(year => year)
        .ToList();

    var minYear = availableYears.Count > 0 ? availableYears.First() : fallbackYear;
    var maxYear = availableYears.Count > 0 ? availableYears.Last() : fallbackYear;
    var currentYear = maxYear;
}

@Html.GetBlockListHtml(Model.Content.Hero)

<section class="o-section">
    <div class="container">
        <div class="c-overview"
             data-component="Overview"
             data-overview-endpoint="@overviewEndpoint"
             data-overview-page-key="@Model.Content.Key"
             data-overview-current-year="@currentYear"
             data-overview-min-year="@minYear"
             data-overview-max-year="@maxYear"
             data-overview-page-size="@pageSize"
             data-overview-ordering="newest">
            <div class="c-overview__top">
                <h2>Evenementen</h2> @* TODO: get from dictionary *@
                
                <div class="c-overview__facets">
                    <div class="c-overview__facets__year">
                        <button type="button" data-overview-year-decrement aria-label="Vorig jaar">
                            <svg class="c-icon" aria-hidden="true"><use href="/dist/images/icons/sprite.svg#chevron-left"></use></svg>
                        </button>
                        <div class="c-overview__facets__year__current" data-overview-year-display>@currentYear</div>
                        <button type="button" data-overview-year-increment aria-label="Volgend jaar">
                            <svg class="c-icon" aria-hidden="true"><use href="/dist/images/icons/sprite.svg#chevron-right"></use></svg>
                        </button>
                    </div>
                    <div class="c-overview__facets__ordering">
                        <select name="ordering-option" id="ordering" data-overview-ordering>
                            <option value="newest" selected>Nieuwste eerst</option> @* TODO: get from dictionary *@
                            <option value="oldest">Oudste eerst</option> @* TODO: get from dictionary *@
                        </select>
                    </div>
                </div>
            </div>
            
            <div class="c-overview__content" data-overview-content aria-live="polite" aria-busy="false">
                @* Content is rendered by JS *@
            </div>
            
            <div class="c-overview__pagination" data-overview-pagination>
                <button type="button" class="c-overview__pagination__arrow" data-overview-page-previous disabled aria-label="Vorige pagina">
                    <svg class="c-icon" aria-hidden="true"><use href="/dist/images/icons/sprite.svg#chevron-left"></use></svg>
                </button>
                <ol class="c-overview__pagination__pages" data-overview-pagination-pages></ol>
                <button type="button" class="c-overview__pagination__arrow" data-overview-page-next disabled aria-label="Volgende pagina">
                    <svg class="c-icon" aria-hidden="true"><use href="/dist/images/icons/sprite.svg#chevron-right"></use></svg>
                </button>
            </div>
        </div>
    </div>
</section>